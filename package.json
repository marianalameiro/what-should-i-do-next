{
  "name": "what-should-i-do-next",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && ELECTRON_DEV=1 electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^1.2.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.mariana.whatshouldidonext",
    "productName": "What Should I Do Next",
    "directories": {
      "output": "dist-electron"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/icon.icns"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
